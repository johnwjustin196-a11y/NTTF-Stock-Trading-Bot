# Copy this file to .env and fill in the values you have.
# Leave blank anything you don't have yet; the bot will fall back to sim mode
# for anything it can't reach.

# Anthropic — used for news sentiment, LLM signal synthesis, and EOD reflection
ANTHROPIC_API_KEY=

# Optional: NewsAPI.org — richer news coverage than the default feedparser/yfinance sources
NEWSAPI_KEY=

# Optional: Finnhub.io — historical fundamental data for backtest deep scorer
FINNHUB_API_KEY=

# Alpaca Markets — paper/live trading + historical data
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://data.alpaca.markets

# Crash/close email alerts — bot emails you when it stops or crashes
# GMAIL_APP_PASSWORD: generate at myaccount.google.com/apppasswords (needs 2FA enabled)
ALERT_EMAIL=
GMAIL_APP_PASSWORD=
